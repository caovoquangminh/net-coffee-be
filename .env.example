# ─── Database ────────────────────────────────────────────────────────────────
DB_URL=jdbc:postgresql://localhost:5432/netcoffee
DB_USERNAME=postgres
DB_PASSWORD=changeme

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Minimum 256-bit random key (openssl rand -hex 32)
JWT_SECRET=replace_with_at_least_32_random_chars

# ─── CORS ────────────────────────────────────────────────────────────────────
# Dev: comma-separated list of allowed origins
# Prod: https://admin.yourshop.vn,app://net-coffee-client
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# ─── File Storage ─────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
BASE_URL=http://localhost:8080

# ─── VietQR Bank Transfer ────────────────────────────────────────────────────
VIETQR_BANK_BIN=970422
VIETQR_BANK_NAME=MB_BANK
VIETQR_ACCOUNT_NUMBER=0123456789
VIETQR_ACCOUNT_NAME=NGUYEN VAN A

# ─── SePay Webhook (optional) ────────────────────────────────────────────────
SEPAY_WEBHOOK_SECRET=

# ─── Telegram Bot (optional) ─────────────────────────────────────────────────
